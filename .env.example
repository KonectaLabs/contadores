CONTADORES_ENABLED=true
INTERNAL_API_TOKEN=

# Funnels configurables por UI/Codex.
# Si se deja vacio, se usa data/funnels.json dentro del volumen persistente.
FUNNELS_CONFIG_PATH=data/funnels.json

# DB: por defecto usa data/database.sqlite en el volumen persistente.
# Dejar DATABASE_URL sin definir salvo migracion deliberada a otra base.

# Sheet de leads. /api/runtime queda not-ready hasta cargar URL y GID.
CONTADORES_SHEET_URL=
CONTADORES_SHEET_GID=
GOOGLE_SERVICE_ACCOUNT_FILE=

# Polling
CONTADORES_SHEET_POLL_SECONDS=30

# Secuencia
# Ping manual en la app: template default contadores_manual_ping_es_v1.
# Marcar booked no envia ping manual ni ningun WhatsApp.
CONTADORES_CALENDLY_BASE_URL=https://calendly.com/facundogoiriz/crecimiento
CONTADORES_ALERT_EMAILS=facundogoiriz@gmail.com,yoelkravchuk@gmail.com
CONTADORES_INITIAL_REPLY_QUIET_SECONDS=30
CONTADORES_POST_LOOM_MIN_SECONDS=600
CONTADORES_POST_LOOM_QUIET_SECONDS=30
CONTADORES_STRATEGY_WEIGHTS_JSON={"loom":{"loom_mp4":100}}
CONTADORES_DELIVERY_MAX_ATTEMPTS=3
CONTADORES_DELIVERY_RETRY_DELAY_SECONDS=60

# Auth local del backend.
# En producción se espera auth.toml montado por Docker Compose.
AUTH_TOML_PATH=auth.toml

# WhatsApp / Meta.
# Los webhooks de Meta pueden traer contacts.profile.name; no requiere env extra.
WA_PHONE_ID=
WA_ACCESS_TOKEN=
WA_VERIFY_TOKEN=
WA_APP_ID=
WA_APP_SECRET=
WA_CALLBACK_URL=
# Ledger local del servicio bot para no perder webhooks inbound si backend falla.
BOT_WEBHOOK_INBOX_PATH=/app/data/bot-webhook-inbox.sqlite
BOT_WEBHOOK_INBOX_PROCESSING_TIMEOUT_SECONDS=120
# Calendly.
CALENDLY_WEBHOOK_SIGNING_KEY=

# AgentMail para alertas humanas.
AGENTMAIL_API_KEY=
AGENTMAIL_DOMAIN=
AGENTMAIL_ALERT_INBOX_ID=
# Alias legacy aceptado para reutilizar el .env de auditor.
AGENTMAIL_CRM_INBOX_ID=
AGENTMAIL_SHARED_INBOX_IDS=
AGENTMAIL_WEBHOOK_URL=
AGENTMAIL_WEBHOOK_SECRET=

# Modelos usados por el bot conversacional y programas DSPy.
OPENAI_API_KEY=
OPENROUTER_API_KEY=
# Modelo principal del bot conversacional por OpenRouter.
# Se usa como fallback DSPy si Codex falla. Si OPENROUTER_API_KEY esta vacio, cae a gpt-5.4-mini.
OPENROUTER_GROK_4_3_MODEL=openrouter/x-ai/grok-4.3

# Bot conversacional runtime: Codex primario + Grok/DSPy fallback.
CONVERSATION_BOT_CODEX_MODEL=gpt-5.5
CONVERSATION_BOT_CODEX_EFFORT=medium
CONVERSATION_BOT_CODEX_SERVICE_TIER=
CONVERSATION_BOT_CODEX_CHATGPT_HOME=/app/data/codex-home-chatgpt
CONVERSATION_BOT_CODEX_API_KEY_HOME=/app/data/codex-home-api-key
CODEX_CHATGPT_REAUTH_URL=https://auth.openai.com/codex/device
# El email de alerta muestra este comando para generar el codigo de 15 minutos.
CODEX_CHATGPT_REAUTH_COMMAND=cd /root/projects/contadores && docker compose exec -it -e OPENAI_API_KEY= -e CODEX_HOME=/app/data/codex-home-chatgpt backend sh -lc 'mkdir -p /app/data/codex-home-chatgpt && codex login --device-auth'

# Workstation solo pagina: templates aprobados para reabrir WhatsApp cuando la
# ventana de 24h esta cerrada. El codigo no manda texto custom fuera de ventana.
WORKSTATION_PING_TEMPLATE_1_NAME=konecta_workstation_ping_1_es_v1
WORKSTATION_PING_TEMPLATE_2_NAME=konecta_workstation_ping_2_es_v1
WORKSTATION_HANDOFF_TEMPLATE_NAME=konecta_workstation_handoff_es_v1
WORKSTATION_TEMPLATE_LANGUAGE=es
WORKSTATION_PING_1_TEXT=Hola, queria saber si pudiste revisar el video de la pagina y si queres que cambiemos algo.
WORKSTATION_PING_2_TEXT=Te escribo para saber si dejamos esa version o si queres algun cambio antes de avanzar.
WORKSTATION_HUMAN_HANDOFF_TEXT=Te dejo con Facu para coordinar el dominio, publicacion y pago final.

# Transcripcion de audios inbound de WhatsApp.
# gpt-4o-transcribe es el default de mayor calidad; gpt-4o-mini-transcribe es fallback barato.
OPENAI_AUDIO_TRANSCRIPTION_MODEL=gpt-4o-transcribe
OPENAI_AUDIO_TRANSCRIPTION_PROMPT=Transcribe audio de WhatsApp de leads de Konecta. Devuelve solo el texto dicho, manteniendo idioma y palabras comerciales como pagina, campanas, reunion, WhatsApp, contadores y abogados.

# Codex SDK usado por Workstation y el endpoint publico de generacion de imagenes.
# true: intenta usar login ChatGPT/Codex guardado en CODEX_HOME.
# false: conserva OPENAI_API_KEY dentro del proceso Codex.
CODEX_HOME=/app/data/codex-home
CODEX_PREFER_CHATGPT_LOGIN=true

# Fallback del endpoint publico cuando Codex no puede generar la imagen.
# OpenAI docs actuales recomiendan gpt-image-1.5; cambiar aca si hay otro modelo habilitado.
OPENAI_IMAGE_FALLBACK_MODEL=gpt-image-1.5
OPENAI_IMAGE_FALLBACK_SIZE=1024x1024
OPENAI_IMAGE_FALLBACK_QUALITY=medium
