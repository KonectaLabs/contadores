CONTADORES_ENABLED=true
INTERNAL_API_TOKEN=

# Funnels configurables por UI/Codex. Fuente principal para usuarios nuevos.
# El seed versionado se carga primero; data/funnels.json pisa esos valores.
FUNNELS_SEED_CONFIG_PATH=config/default-funnels.json
# Si se deja vacio, se usa data/funnels.json dentro del volumen persistente.
FUNNELS_CONFIG_PATH=data/funnels.json

# DB: por defecto usa data/database.sqlite en el volumen persistente.
# Dejar DATABASE_URL sin definir salvo migracion deliberada a otra base.

# Legacy env fallback. Para funnels reales, preferir config/default-funnels.json
# y data/funnels.json.
# /api/runtime queda ready cuando al menos un campaign funnel habilitado tiene URL y GID.
CONTADORES_SHEET_URL=
CONTADORES_SHEET_GID=
# Client Lead Delivery y lectores privados intentan primero export publico.
# Si la sheet es privada, usar una credencial con permiso de lectura.
CONTADORES_GOOGLE_SERVICE_ACCOUNT_FILE=
GOOGLE_SERVICE_ACCOUNT_FILE=
# Delivery sources configurables por archivo. El seed versionado se carga primero;
# data/client-lead-sources.json pisa esos valores y se importa a la DB al arrancar.
CLIENT_LEAD_SOURCES_SEED_CONFIG_PATH=config/default-client-lead-sources.json
CLIENT_LEAD_SOURCES_CONFIG_PATH=data/client-lead-sources.json

# Polling
CONTADORES_SHEET_POLL_SECONDS=30

# Secuencia
# Ping manual en la app: template default contadores_manual_ping_es_v1.
# Marcar Converted no envia ping manual ni ningun WhatsApp.
CONTADORES_CALENDLY_BASE_URL=
CONTADORES_ALERT_EMAILS=
CONTADORES_INITIAL_REPLY_QUIET_SECONDS=30
CONTADORES_POST_LOOM_MIN_SECONDS=600
CONTADORES_POST_LOOM_QUIET_SECONDS=30
CONTADORES_STRATEGY_WEIGHTS_JSON={"loom":{"text_offer_599":100}}
CONTADORES_DELIVERY_MAX_ATTEMPTS=3
CONTADORES_DELIVERY_RETRY_DELAY_SECONDS=60

# Auth local del backend.
# En producción se espera auth.toml montado por Docker Compose.
AUTH_TOML_PATH=auth.toml

# WhatsApp / Meta.
# Los webhooks de Meta pueden traer contacts.profile.name; no requiere env extra.
WA_PHONE_ID=
WA_ACCESS_TOKEN=
WA_VERIFY_TOKEN=
WA_APP_ID=
WA_APP_SECRET=
WA_CALLBACK_URL=https://crm.fgoiriz.com/webhook/wa
CONTADORES_REVIEW_BASE_URL=https://crm.fgoiriz.com
# Ledger local del servicio bot para no perder webhooks inbound si backend falla.
BOT_WEBHOOK_INBOX_PATH=/app/data/bot-webhook-inbox.sqlite
BOT_WEBHOOK_INBOX_PROCESSING_TIMEOUT_SECONDS=120

# Meta Marketing API publishing and Lead Ads retrieval.
# El mismo token se usa para inventario/read-only Lead Ads fetch. Por defecto
# solo se hace preflight/dry-run; no activar live writes sin aprobar politica de
# publicacion, permisos y limites de presupuesto.
META_MARKETING_API_VERSION=
META_MARKETING_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
META_BUSINESS_ID=
META_PAGE_ID=
META_WHATSAPP_PHONE_NUMBER_ID=
META_WHATSAPP_BUSINESS_ACCOUNT_ID=
META_MARKETING_LIVE_WRITES_ENABLED=false
META_LEAD_WEBHOOK_VERIFY_TOKEN=
META_LEAD_WEBHOOK_DEFAULT_SOURCE_ID=

# Google Calendar meeting scheduling.
# schedule_platform_meeting puede hacer dry-run sin estas variables. Para crear
# eventos reales con asistentes, configurar calendar_id, asistentes internos,
# service account y usuario delegado con Domain-Wide Delegation.
PLATFORM_MEETING_CALENDAR_ID=
PLATFORM_MEETING_INTERNAL_ATTENDEES=
GOOGLE_CALENDAR_SERVICE_ACCOUNT_FILE=
GOOGLE_CALENDAR_DELEGATED_USER=
# Legacy scheduling link / Calendly.
CALENDLY_WEBHOOK_SIGNING_KEY=

# AgentMail para alertas humanas.
AGENTMAIL_API_KEY=
AGENTMAIL_DOMAIN=
AGENTMAIL_ALERT_INBOX_ID=
# Alias legacy aceptado para reutilizar el .env de auditor.
AGENTMAIL_CRM_INBOX_ID=
AGENTMAIL_SHARED_INBOX_IDS=
AGENTMAIL_WEBHOOK_URL=
AGENTMAIL_WEBHOOK_SECRET=

# Cloudflare Registrar / DNS automation.
# Preferir API token scoped. Registrar write puede comprar dominios.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
# Fallback legacy si el token scoped todavia no existe.
CLOUDFLARE_API_EMAIL=
CLOUDFLARE_API_KEY=

# Modelos usados por el bot conversacional y programas DSPy.
OPENAI_API_KEY=
OPENROUTER_API_KEY=
# Modelo principal del bot conversacional por OpenRouter.
# Se usa como fallback DSPy si Codex falla. Si OPENROUTER_API_KEY esta vacio, cae a gpt-5.4-mini.
OPENROUTER_GROK_4_3_MODEL=openrouter/x-ai/grok-4.3

# Bot conversacional y Workstation solo pagina (Codex SDK):
# Por defecto el SDK no corre: sin tokens Codex (ni ChatGPT ni API key).
# OPENAI_API_KEY solo no enciende Codex: hace falta CODEX_BACKEND_ENABLED=true.
# Para Codex por API key: ambos anteriores; para sesion ChatGPT ademas CODEX_PREFER_CHATGPT_LOGIN=true.
# ChatGPT/Codex por sesion guardada es opt-in: CODEX_PREFER_CHATGPT_LOGIN=true
# y rutas CODEX_HOME / CONVERSATION_BOT_CODEX_CHATGPT_HOME si aplica.
CONTADORES_LEAD_CODEX_ENABLED_DEFAULT=false
CODEX_BACKEND_ENABLED=false
CODEX_PREFER_CHATGPT_LOGIN=false
CONVERSATION_BOT_CODEX_MODEL=gpt-5.5
CONVERSATION_BOT_CODEX_EFFORT=medium
CONVERSATION_BOT_CODEX_SERVICE_TIER=
# Antiduplicado cross-process para batches de respuestas del bot conversacional.
CONVERSATION_PROCESSING_STALE_SECONDS=1200

# Runtime autonomo Codex con tools internas auditadas.
# Mantener apagado globalmente hasta probar en local/server con un lead real controlado.
# Cuando esta activo, Codex carga la skill contadores-agent-harness, puede llamar
# tools por CLI, escribir memoria en data/agent-memory/ y agendar heartbeats en
# scheduled_agent_tasks.
CODEX_AGENT_TOOLS_ENABLED=false
CODEX_AGENT_TOOLS_WORKSTATION_ENABLED=false
CODEX_AGENT_TOOLS_CONVERSATION_ENABLED=false

# Workstation solo pagina: templates aprobados para reabrir WhatsApp cuando la
# ventana de 24h esta cerrada. El codigo no manda texto custom fuera de ventana.
WORKSTATION_PING_TEMPLATE_1_NAME=konecta_workstation_ping_1_es_v1
WORKSTATION_PING_TEMPLATE_2_NAME=konecta_workstation_ping_2_es_v1
WORKSTATION_HANDOFF_TEMPLATE_NAME=konecta_workstation_handoff_es_v1
WORKSTATION_TEMPLATE_LANGUAGE=es
WORKSTATION_PING_1_TEXT=Hola, queria saber si pudiste revisar el video de la pagina y si queres que cambiemos algo.
WORKSTATION_PING_2_TEXT=Te escribo para saber si dejamos esa version o si queres algun cambio antes de avanzar.
WORKSTATION_HUMAN_HANDOFF_TEXT=Te dejo con Facu para coordinar el dominio, publicacion y pago final.
# Origen publico estable usado para links de prueba /p/{token}/ de Workstation.
# En produccion debe ser el dominio publico servido por Traefik, sin slash final.
WORKSTATION_PUBLIC_PAGE_BASE_URL=https://crm.fgoiriz.com
# Revisa clientes Workstation solo-page cada 12h con Codex y permite no hacer nada.
WORKSTATION_CODEX_HEARTBEAT_ENABLED=true
WORKSTATION_CODEX_HEARTBEAT_INTERVAL_HOURS=12

# Transcripcion de audios inbound de WhatsApp.
# gpt-4o-transcribe es el default de mayor calidad; gpt-4o-mini-transcribe es fallback barato.
OPENAI_AUDIO_TRANSCRIPTION_MODEL=gpt-4o-transcribe
OPENAI_AUDIO_TRANSCRIPTION_PROMPT=Transcribe audio de WhatsApp de leads de Konecta. Devuelve solo el texto dicho, manteniendo idioma y palabras comerciales como pagina, campanas, reunion, WhatsApp, contadores y abogados.

# Opcional: homes separados para Codex (solo si habilitas Codex arriba).
# CODEX_HOME=
# CONVERSATION_BOT_CODEX_CHATGPT_HOME=
# CONVERSATION_BOT_CODEX_API_KEY_HOME=
# CODEX_CHATGPT_REAUTH_URL=
# CODEX_CHATGPT_REAUTH_COMMAND=
